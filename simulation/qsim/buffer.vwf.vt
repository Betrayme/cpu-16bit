		( test_buffer_expected_prev[11] !== 1'bx ) && ( test_buffer_prev[11] !== test_buffer_expected_prev[11] )
		&& ((test_buffer_expected_prev[11] !== last_test_buffer_exp[11]) ||
			on_first_change[2])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port test_buffer[11] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", test_buffer_expected_prev);
		$display ("     Real value = %b", test_buffer_prev);
		nummismatches = nummismatches + 1;
		on_first_change[2] = 1'b0;
		last_test_buffer_exp[11] = test_buffer_expected_prev[11];
	end
	if (
		( test_buffer_expected_prev[12] !== 1'bx ) && ( test_buffer_prev[12] !== test_buffer_expected_prev[12] )
		&& ((test_buffer_expected_prev[12] !== last_test_buffer_exp[12]) ||
			on_first_change[2])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port test_buffer[12] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", test_buffer_expected_prev);
		$display ("     Real value = %b", test_buffer_prev);
		nummismatches = nummismatches + 1;
		on_first_change[2] = 1'b0;
		last_test_buffer_exp[12] = test_buffer_expected_prev[12];
	end
	if (
		( test_buffer_expected_prev[13] !== 1'bx ) && ( test_buffer_prev[13] !== test_buffer_expected_prev[13] )
		&& ((test_buffer_expected_prev[13] !== last_test_buffer_exp[13]) ||
			on_first_change[2])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port test_buffer[13] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", test_buffer_expected_prev);
		$display ("     Real value = %b", test_buffer_prev);
		nummismatches = nummismatches + 1;
		on_first_change[2] = 1'b0;
		last_test_buffer_exp[13] = test_buffer_expected_prev[13];
	end
	if (
		( test_buffer_expected_prev[14] !== 1'bx ) && ( test_buffer_prev[14] !== test_buffer_expected_prev[14] )
		&& ((test_buffer_expected_prev[14] !== last_test_buffer_exp[14]) ||
			on_first_change[2])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port test_buffer[14] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", test_buffer_expected_prev);
		$display ("     Real value = %b", test_buffer_prev);
		nummismatches = nummismatches + 1;
		on_first_change[2] = 1'b0;
		last_test_buffer_exp[14] = test_buffer_expected_prev[14];
	end
	if (
		( test_buffer_expected_prev[15] !== 1'bx ) && ( test_buffer_prev[15] !== test_buffer_expected_prev[15] )
		&& ((test_buffer_expected_prev[15] !== last_test_buffer_exp[15]) ||
			on_first_change[2])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port test_buffer[15] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", test_buffer_expected_prev);
		$display ("     Real value = %b", test_buffer_prev);
		nummismatches = nummismatches + 1;
		on_first_change[2] = 1'b0;
		last_test_buffer_exp[15] = test_buffer_expected_prev[15];
	end

	trigger <= ~trigger;
end
initial 

begin 
$timeformat(-12,3," ps",6);
#1000000;
if (nummismatches > 0)
	$display ("%d mismatched vectors : Simulation failed !",nummismatches);
else
	$display ("Simulation passed !");
$finish;
end 
endmodule

module buffer_vlg_vec_tst();
// constants                                           
// general purpose registers
reg CLK;
reg [15:0] a;
reg en;
reg rst;
// wires                                               
wire [15:0] q;
wire [15:0] test_buffer;

wire sampler;                             

// assign statements (if any)                          
buffer i1 (
// port map - connection between master ports and signals/registers   
	.CLK(CLK),
	.a(a),
	.en(en),
	.q(q),
	.rst(rst),
	.test_buffer(test_buffer)
);

// CLK
initial
begin
	CLK = 1'b0;
	CLK = #30000 1'b1;
	CLK = #40000 1'b0;
end 
// a[ 15 ]
initial
begin
	a[15] = 1'b0;
end 
// a[ 14 ]
initial
begin
	a[14] = 1'b0;
end 
// a[ 13 ]
initial
begin
	a[13] = 1'b0;
end 
// a[ 12 ]
initial
begin
	a[12] = 1'b1;
end 
// a[ 11 ]
initial
begin
	a[11] = 1'b0;
end 
// a[ 10 ]
initial
begin
	a[10] = 1'b0;
end 
// a[ 9 ]
initial
begin
	a[9] = 1'b1;
end 
// a[ 8 ]
initial
begin
	a[8] = 1'b0;
end 
// a[ 7 ]
initial
begin
	a[7] = 1'b0;
end 
// a[ 6 ]
initial
begin
	a[6] = 1'b0;
end 
// a[ 5 ]
initial
begin
	a[5] = 1'b1;
end 
// a[ 4 ]
initial
begin
	a[4] = 1'b1;
end 
// a[ 3 ]
initial
begin
	a[3] = 1'b0;
end 
// a[ 2 ]
initial
begin
	a[2] = 1'b1;
end 
// a[ 1 ]
initial
begin
	a[1] = 1'b0;
end 
// a[ 0 ]
initial
begin
	a[0] = 1'b0;
end 

// en
initial
begin
	en = 1'b0;
	en = #140000 1'b1;
	en = #120000 1'b0;
end 

// rst
initial
begin
	rst = 1'b0;
	rst = #10000 1'b1;
	rst = #10000 1'b0;
end 

buffer_vlg_sample_tst tb_sample (
	.CLK(CLK),
	.a(a),
	.en(en),
	.rst(rst),
	.sampler_tx(sampler)
);

buffer_vlg_check_tst tb_out(
	.q(q),
	.test_buffer(test_buffer),
	.sampler_rx(sampler)
);
endmodule

