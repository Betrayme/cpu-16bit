`timescale 1 ps/ 1 ps
module buffer_vlg_sample_tst(
	CLK,
	a,
	en,
	rst,
	sampler_tx
);
input  CLK;
input [15:0] a;
input  en;
input  rst;
output sampler_tx;

reg sample;
time current_time;
always @(CLK or a or en or rst)
                                                                                
begin                                                 
 if ($realtime > 0)                                   
 begin                                                
	if ($realtime == 0 || $realtime != current_time)  
	begin									          
		if (sample === 1'bx)                          
			sample = 0;                               
		else                                          
			sample = ~sample;                         
	end										          
	current_time = $realtime;					      
 end                                                  
end                                                   

assign sampler_tx = sample;
endmodule

