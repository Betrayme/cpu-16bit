`timescale 1 ps/ 1 ps
module CPU16bit_vlg_sample_tst(
	CLK,
	RST,
	STEP,
	sampler_tx
);
input  CLK;
input  RST;
input  STEP;
output sampler_tx;

reg sample;
time current_time;
always @(CLK or RST or STEP)
                                                                                
begin                                                 
 if ($realtime > 0)                                   
 begin                                                
	if ($realtime == 0 || $realtime != current_time)  
	begin									          
		if (sample === 1'bx)                          
			sample = 0;                               
		else                                          
			sample = ~sample;                         
	end										          
	current_time = $realtime;					      
 end                                                  
end                                                   

assign sampler_tx = sample;
endmodule

