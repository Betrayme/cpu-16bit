endmodule

module CPU16bit_vlg_vec_tst();
// constants                                           
// general purpose registers
reg CLK;
reg RST;
reg STEP;
// wires                                               
wire [15:0] DataBus;
wire [15:0] test_PC;
wire test_T1;
wire test_T2;
wire [15:0] test_buffer;
wire [4:0] test_currentstate;
wire [15:0] test_instrReg;

wire sampler;                             

// assign statements (if any)                          
CPU16bit i1 (
// port map - connection between master ports and signals/registers   
	.CLK(CLK),
	.DataBus(DataBus),
	.RST(RST),
	.STEP(STEP),
	.test_PC(test_PC),
	.test_T1(test_T1),
	.test_T2(test_T2),
	.test_buffer(test_buffer),
	.test_currentstate(test_currentstate),
	.test_instrReg(test_instrReg)
);

// RST
initial
begin
	RST = 1'b0;
	RST = #1280000 1'b1;
	RST = #1280000 1'b0;
end 

// CLK
always
begin
	CLK = 1'b0;
	CLK = #500000 1'b1;
	#500000;
end 

// STEP
always
begin
	STEP = 1'b0;
	STEP = #2000000 1'b1;
	#2000000;
end 

CPU16bit_vlg_sample_tst tb_sample (
	.CLK(CLK),
	.RST(RST),
	.STEP(STEP),
	.sampler_tx(sampler)
);

CPU16bit_vlg_check_tst tb_out(
	.DataBus(DataBus),
	.test_PC(test_PC),
	.test_T1(test_T1),
	.test_T2(test_T2),
	.test_buffer(test_buffer),
	.test_currentstate(test_currentstate),
	.test_instrReg(test_instrReg),
	.sampler_rx(sampler)
);
endmodule

